+import React from 'react';
+import { BrowserRouter, Navigate, Route, Routes } from 'react-router-dom';
+import Navbar from './components/Navbar';
+import Sidebar from './components/Sidebar';
+import LoginPage from './pages/LoginPage';
+import JobSeekerDashboard from './pages/JobSeekerDashboard';
+import RecruiterDashboard from './pages/RecruiterDashboard';
+import AdminDashboard from './pages/AdminDashboard';
+import { navItems } from './data/mockData';
+import './styles/global.css';
+
+const DashboardLayout = ({ role, heading, userName, children }) => (
+  <div className="app-shell">
+    <Sidebar title={`${role} Panel`} items={navItems[role]} />
+    <div className="main-panel">
+      <Navbar heading={heading} userName={userName} />
+      <div className="content-area">{children}</div>
+    </div>
+  </div>
+);
+
+const App = () => (
+  <BrowserRouter>
+    <Routes>
+      <Route path="/" element={<LoginPage />} />
+      <Route
+        path="/job-seeker"
+        element={(
+          <DashboardLayout role="seeker" heading="Job Seeker Dashboard" userName="Rahul">
+            <JobSeekerDashboard />
+          </DashboardLayout>
+        )}
+      />
+      <Route
+        path="/recruiter"
+        element={(
+          <DashboardLayout role="recruiter" heading="Recruiter Dashboard" userName="Nikita">
+            <RecruiterDashboard />
+          </DashboardLayout>
+        )}
+      />
+      <Route
+        path="/admin"
+        element={(
+          <DashboardLayout role="admin" heading="Admin Dashboard" userName="System Admin">
+            <AdminDashboard />
+          </DashboardLayout>
+        )}
+      />
+      <Route path="*" element={<Navigate to="/" replace />} />
+    </Routes>
+  </BrowserRouter>
+);
+
+export default App;
