+++ b/src/components/ATSScoreCircle.js
@@ -0,0 +1,21 @@
+import React from 'react';
+
+const ATSScoreCircle = ({ score }) => {
+  const degree = Math.round((score / 100) * 360);
+
+  return (
+    <div
+      className="score-circle"
+      style={{
+        background: `conic-gradient(#4f7dff ${degree}deg, #e7ecff ${degree}deg)`
+      }}
+    >
+      <div className="score-inner">
+        <h3>{score}%</h3>
+        <span>ATS Score</span>
+      </div>
+    </div>
+  );
+};
+
+export default ATSScoreCircle;
